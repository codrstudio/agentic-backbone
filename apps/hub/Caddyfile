# Caddyfile do container hub — serve SPA estatico (Vite build) na porta 80.
# O service caddy (infra/docker-compose.platform.yml) faz reverse_proxy
# /hub/* -> hub.internal:80, depois este Caddy serve o dist/.
#
# - `handle_path` strip do prefixo /hub/ se vier com ele (fallback defensivo)
# - try_files pra SPA routing (tudo cai no index.html se nao for arquivo)
# - PWA precisa que sw.js e manifest.webmanifest sejam servidos com content-type correto — Caddy detecta pelo file_server.

:{$HUB_PORT} {
    # Gateway envia paths com prefixo /hub (Caddyfile do proxy usa `handle`
    # sem strip). Aqui removemos o prefixo pra casar com a estrutura do dist.
    # Requer que o Vite tenha sido buildado com `base: '/hub/'`.
    uri strip_prefix /hub

    root * /srv/hub

    # SPA routing: rotas client-side caem no index.html
    try_files {path} /index.html

    file_server

    # Cache agressivo pros assets com hash no nome (vite adiciona -[hash].js/.css)
    @hashed path_regexp ^/assets/.+\-[0-9a-f]{8,}\.(js|css|png|svg|woff2?)$
    header @hashed Cache-Control "public, max-age=31536000, immutable"

    # PWA: service worker NAO deve ser cacheado
    @sw path /sw.js /registerSW.js
    header @sw Cache-Control "no-cache"

    encode gzip zstd
}
